<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sandbox выключен: чтение SMC/HID-сенсоров недоступно из песочницы.
         Это локальный инструмент; см. README про последствия для распространения. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
